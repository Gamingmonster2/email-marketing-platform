---
const { frontmatter } = Astro.props;
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title} | email.com.ly</title>
    <style>
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f8fafc;
            color: #0f172a;
            margin: 0;
            padding: 0;
            line-height: 1.7;
        }
        .article-wrapper {
            max-width: 760px;
            margin: 40px auto;
            padding: 30px;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
        }
        .hero-img {
            width: 100%;
            max-height: 380px;
            object-fit: cover;
            border-radius: 12px;
            margin-bottom: 25px;
        }
        h1 {
            font-size: 2.1rem;
            color: #1e293b;
            line-height: 1.4;
            margin-bottom: 10px;
        }
        .publish-date {
            font-size: 0.85rem;
            color: #64748b;
            display: block;
            margin-bottom: 25px;
        }
        .prose {
            font-size: 1.1rem;
            color: #334155;
        }
        .prose h2, .prose h3 {
            color: #0f172a;
            margin-top: 1.8em;
            margin-bottom: 0.8em;
        }
    </style>
</head>
<body>
    <article class="article-wrapper">
        {frontmatter.image && <img src={frontmatter.image} alt={frontmatter.title} class="hero-img" />}
        <h1>{frontmatter.title}</h1>
        <span class="publish-date">تاريخ النشر: {frontmatter.date}</span>
        <hr style="border: none; border-top: 1px solid #e2e8f0; margin-bottom: 25px;" />
        <div class="prose">
            <slot />
        </div>
    </article>
</body>
</html>
